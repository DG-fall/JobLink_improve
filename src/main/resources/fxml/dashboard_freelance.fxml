<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.joblink.controller.DashboardFreelance" 
            prefWidth="1400" prefHeight="900"
            stylesheets="@../css/styles.css">
    
    <!-- Sidebar -->
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="260" spacing="4">
            
            <!-- Sidebar Header -->
            <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 12;"
                           prefWidth="44" prefHeight="44" alignment="CENTER">
                    <FontIcon iconLiteral="fth-briefcase" iconSize="22" style="-fx-icon-color: white;" />
                </StackPane>
                <Label text="JobLink" styleClass="sidebar-logo" />
            </HBox>
            
            <!-- Navigation -->
            <VBox styleClass="sidebar-nav" spacing="4">
                <Label text="PRINCIPAL" styleClass="sidebar-section-title" />
                <padding><Insets top="8" /></padding>
                
                <Button fx:id="btnHome" text="Tableau de bord" styleClass="nav-button, active" maxWidth="Infinity" onAction="#showHome">
                    <graphic>
                        <FontIcon iconLiteral="fth-home" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnMarketplace" text="Marketplace" styleClass="nav-button" maxWidth="Infinity" onAction="#showMarketplace">
                    <graphic>
                        <FontIcon iconLiteral="fth-search" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnPropositions" text="Mes Propositions" styleClass="nav-button" maxWidth="Infinity" onAction="#showPropositions">
                    <graphic>
                        <FontIcon iconLiteral="fth-send" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnPortfolio" text="Mon Portfolio" styleClass="nav-button" maxWidth="Infinity" onAction="#showPortfolio">
                    <graphic>
                        <FontIcon iconLiteral="fth-grid" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnRevenus" text="Mes Revenus" styleClass="nav-button" maxWidth="Infinity" onAction="#showRevenus">
                    <graphic>
                        <FontIcon iconLiteral="fth-trending-up" iconSize="20" />
                    </graphic>
                </Button>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <!-- Bottom Navigation -->
            <VBox styleClass="sidebar-nav" spacing="4">
                <Label text="COMPTE" styleClass="sidebar-section-title" />
                <padding><Insets top="8" /></padding>
                
                <Button fx:id="btnMessages" text="Messages" styleClass="nav-button" maxWidth="Infinity" onAction="#showMessages">
                    <graphic>
                        <FontIcon iconLiteral="fth-message-circle" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnProfileFreelance" text="Mon Profil" styleClass="nav-button" maxWidth="Infinity" onAction="#showProfile">
                    <graphic>
                        <FontIcon iconLiteral="fth-user" iconSize="20" />
                    </graphic>
                </Button>
            </VBox>
            
            <!-- Sidebar Footer with User -->
            <VBox styleClass="sidebar-footer">
                <HBox styleClass="sidebar-user" alignment="CENTER_LEFT" spacing="12">
                    <StackPane styleClass="avatar, avatar-md" 
                               style="-fx-background-color: rgba(255,255,255,0.25);">
                        <Label fx:id="userInitials" text="F" 
                               style="-fx-text-fill: white; -fx-font-weight: 700; -fx-font-size: 14px;" />
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="userNameLabel" text="Freelance" styleClass="sidebar-user-name" />
                        <Label text="Freelance" styleClass="sidebar-user-role" />
                    </VBox>
                    <Button styleClass="icon-button" onAction="#handleLogout" 
                            style="-fx-background-color: transparent;">
                        <graphic>
                            <FontIcon iconLiteral="fth-log-out" iconSize="18" style="-fx-icon-color: rgba(255,255,255,0.7);" />
                        </graphic>
                    </Button>
                </HBox>
            </VBox>
        </VBox>
    </left>
    
    <!-- Main Content -->
    <center>
        <VBox style="-fx-background-color: -fx-color-background;">
            
            <!-- Top Bar -->
            <HBox styleClass="top-bar" alignment="CENTER" spacing="16">
                <Button fx:id="btnSidebarToggle" styleClass="icon-button" onAction="#toggleSidebar">
                    <graphic>
                        <FontIcon iconLiteral="fth-menu" iconSize="20" />
                    </graphic>
                </Button>
                
                <!-- Search -->
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: -fx-color-background-secondary; -fx-background-radius: 10; -fx-padding: 0 16;">
                    <FontIcon iconLiteral="fth-search" iconSize="18" style="-fx-icon-color: #94A3B8;" />
                    <TextField fx:id="searchField" promptText="Rechercher des missions..." 
                               styleClass="search-field"
                               style="-fx-background-color: transparent; -fx-border-color: transparent;" />
                </HBox>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- Actions -->
                <Button fx:id="btnThemeToggle" styleClass="icon-button" onAction="#toggleTheme">
                    <graphic>
                        <FontIcon iconLiteral="fth-moon" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnNotifications" styleClass="icon-button" onAction="#showNotifications">
                    <graphic>
                        <FontIcon iconLiteral="fth-bell" iconSize="20" />
                    </graphic>
                </Button>
            </HBox>
            
            <!-- Content Area -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" styleClass="content-area">
                <!-- Dynamic content loaded here -->
            </StackPane>
        </VBox>
    </center>
</BorderPane>
