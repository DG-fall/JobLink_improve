<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.joblink.controller.DashboardFreelance" prefWidth="1280" prefHeight="800">
    
    <left>
        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="250" spacing="8">
            <padding><Insets top="20" right="15" bottom="20" left="15" /></padding>
            
            <HBox alignment="CENTER_LEFT" spacing="15">
                <padding><Insets bottom="25" /></padding>
                <Button fx:id="btnSidebarToggle" styleClass="icon-button" onAction="#toggleSidebar">
                    <graphic>
                        <FontIcon iconLiteral="fth-menu" iconSize="24" />
                    </graphic>
                </Button>
                <FontIcon fx:id="logoIcon" iconLiteral="fth-briefcase" iconSize="28" style="-fx-icon-color: -fx-color-primary;" />
                <Label text="JobLink" styleClass="sidebar-title" />
            </HBox>
            
            <Label text="PRINCIPAL" style="-fx-font-size: 10px; -fx-text-fill: -fx-color-muted-foreground; -fx-font-weight: bold; -fx-padding: 5 0 3 10;" />
            
            <Button fx:id="btnMarketplace" text="Marketplace" styleClass="nav-button, active" maxWidth="Infinity" onAction="#showMarketplace">
                <graphic>
                    <FontIcon iconLiteral="fth-globe" iconSize="20" />
                </graphic>
            </Button>
            <Button fx:id="btnPropositions" text="Mes Propositions" styleClass="nav-button" maxWidth="Infinity" onAction="#showPropositions">
                <graphic>
                    <FontIcon iconLiteral="fth-file-text" iconSize="20" />
                </graphic>
            </Button>
            <Button fx:id="btnPortfolio" text="Mon Portfolio" styleClass="nav-button" maxWidth="Infinity" onAction="#showPortfolio">
                <graphic>
                    <FontIcon iconLiteral="fth-image" iconSize="20" />
                </graphic>
            </Button>
            <Button fx:id="btnRevenus" text="Mes Revenus" styleClass="nav-button" maxWidth="Infinity" onAction="#showRevenus">
                <graphic>
                    <FontIcon iconLiteral="fth-dollar-sign" iconSize="20" />
                </graphic>
            </Button>
            
            <Region VBox.vgrow="ALWAYS" />
            
            <Label text="COMPTE" style="-fx-font-size: 10px; -fx-text-fill: -fx-color-muted-foreground; -fx-font-weight: bold; -fx-padding: 5 0 3 10;" />
            <Button fx:id="btnMessages" text="Messages" styleClass="nav-button" maxWidth="Infinity" onAction="#showMessages">
                <graphic>
                    <FontIcon iconLiteral="fth-message-circle" iconSize="20" />
                </graphic>
            </Button>
            <Button fx:id="btnProfileFreelance" text="Profil &amp; Évaluations" styleClass="nav-button" maxWidth="Infinity" onAction="#showProfile">
                <graphic>
                    <FontIcon iconLiteral="fth-user" iconSize="20" />
                </graphic>
            </Button>
            <Button fx:id="btnLogout" text="Se déconnecter" styleClass="nav-button" style="-fx-text-fill: -fx-color-destructive;" maxWidth="Infinity" onAction="#handleLogout">
                <graphic>
                    <FontIcon iconLiteral="fth-log-out" iconSize="20" style="-fx-icon-color: -fx-color-destructive;" />
                </graphic>
            </Button>
        </VBox>
    </left>
    
    <center>
        <VBox>
            <HBox styleClass="top-bar" alignment="CENTER_RIGHT" spacing="20">
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnThemeToggle" styleClass="icon-button" onAction="#toggleTheme">
                    <graphic>
                        <FontIcon iconLiteral="fth-moon" iconSize="20" />
                    </graphic>
                </Button>
                <Button fx:id="btnNotifications" styleClass="icon-button" onAction="#showNotifications">
                    <graphic>
                        <FontIcon iconLiteral="fth-bell" iconSize="20" />
                    </graphic>
                </Button>
                <Label text="Freelance" style="-fx-text-fill: -fx-color-muted-foreground; -fx-font-size: 13px;" />
                <Label fx:id="userNameLabel" style="-fx-font-weight: bold; -fx-font-size: 15px;" />
                <Circle style="-fx-fill: -fx-color-primary;" radius="16" />
            </HBox>
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS">
                <padding><Insets top="30" right="40" bottom="30" left="40" /></padding>
            </StackPane>
        </VBox>
    </center>
</BorderPane>
