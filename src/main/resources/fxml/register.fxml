<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.joblink.controller.LoginController" 
      prefWidth="1200" prefHeight="800" 
      styleClass="auth-container"
      stylesheets="@../css/styles.css">
    
    <!-- Left Panel - Form -->
    <ScrollPane HBox.hgrow="ALWAYS" fitToWidth="true" fitToHeight="true"
                style="-fx-background-color: #F8FAFC; -fx-background: #F8FAFC;">
        <VBox alignment="CENTER" style="-fx-background-color: #F8FAFC;">
            <padding>
                <Insets top="40" right="80" bottom="40" left="80" />
            </padding>
            
            <!-- Register Card -->
            <VBox maxWidth="480" alignment="CENTER_LEFT" spacing="6" styleClass="auth-card">
                
                <!-- Header -->
                <VBox spacing="8" alignment="CENTER">
                    <HBox alignment="CENTER" spacing="10">
                        <FontIcon iconLiteral="fth-user-plus" iconSize="28" style="-fx-icon-color: #4F46E5;" />
                        <Label text="JobLink" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #4F46E5;" />
                    </HBox>
                    <Region prefHeight="8" />
                    <Label text="Creer votre compte" styleClass="auth-title" />
                    <Label text="Rejoignez la communaute JobLink" styleClass="auth-subtitle" />
                </VBox>
                
                <Region prefHeight="20" />
                
                <!-- Form -->
                <VBox spacing="16">
                    <!-- Name Row -->
                    <HBox spacing="16">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Nom" styleClass="form-label" />
                            <TextField fx:id="nomField" promptText="Votre nom" />
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Prenom" styleClass="form-label" />
                            <TextField fx:id="prenomField" promptText="Votre prenom" />
                        </VBox>
                    </HBox>
                    
                    <!-- Email -->
                    <VBox spacing="6">
                        <Label text="Adresse email" styleClass="form-label" />
                        <HBox styleClass="text-field" style="-fx-padding: 0;">
                            <HBox alignment="CENTER" style="-fx-padding: 0 12 0 16;">
                                <FontIcon iconLiteral="fth-mail" iconSize="18" style="-fx-icon-color: #94A3B8;" />
                            </HBox>
                            <TextField fx:id="emailField" promptText="exemple@email.com" 
                                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 12 16 12 8;"
                                       HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>
                    
                    <!-- Password -->
                    <VBox spacing="6">
                        <Label text="Mot de passe" styleClass="form-label" />
                        <HBox styleClass="text-field" style="-fx-padding: 0;">
                            <HBox alignment="CENTER" style="-fx-padding: 0 12 0 16;">
                                <FontIcon iconLiteral="fth-lock" iconSize="18" style="-fx-icon-color: #94A3B8;" />
                            </HBox>
                            <PasswordField fx:id="passwordField" promptText="Minimum 8 caracteres" 
                                           style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 12 16 12 8;"
                                           HBox.hgrow="ALWAYS" />
                        </HBox>
                        <Label text="Utilisez au moins 8 caracteres avec des lettres et des chiffres" 
                               styleClass="form-hint" />
                    </VBox>
                    
                    <!-- Role Selection -->
                    <VBox spacing="10">
                        <Label text="Je suis un" styleClass="form-label" />
                        <HBox spacing="16">
                            <!-- Client Option -->
                            <HBox fx:id="clientOption" alignment="CENTER_LEFT" spacing="12" 
                                  style="-fx-background-color: #F1F5F9; -fx-background-radius: 12; -fx-padding: 16; -fx-cursor: hand;"
                                  HBox.hgrow="ALWAYS">
                                <StackPane style="-fx-background-color: #DBEAFE; -fx-background-radius: 10;"
                                           prefWidth="40" prefHeight="40" alignment="CENTER">
                                    <FontIcon iconLiteral="fth-briefcase" iconSize="20" style="-fx-icon-color: #3B82F6;" />
                                </StackPane>
                                <VBox spacing="2">
                                    <RadioButton fx:id="clientRadio" text="Client" 
                                                 style="-fx-font-weight: 600; -fx-font-size: 14px;" 
                                                 selected="true" onAction="#handleRoleSwitch" />
                                    <Label text="Je cherche des freelances" 
                                           style="-fx-font-size: 12px; -fx-text-fill: #64748B;" />
                                </VBox>
                            </HBox>
                            
                            <!-- Freelance Option -->
                            <HBox fx:id="freelanceOption" alignment="CENTER_LEFT" spacing="12" 
                                  style="-fx-background-color: #F1F5F9; -fx-background-radius: 12; -fx-padding: 16; -fx-cursor: hand;"
                                  HBox.hgrow="ALWAYS">
                                <StackPane style="-fx-background-color: #F3E8FF; -fx-background-radius: 10;"
                                           prefWidth="40" prefHeight="40" alignment="CENTER">
                                    <FontIcon iconLiteral="fth-user" iconSize="20" style="-fx-icon-color: #8B5CF6;" />
                                </StackPane>
                                <VBox spacing="2">
                                    <RadioButton fx:id="freelanceRadio" text="Freelance" 
                                                 style="-fx-font-weight: 600; -fx-font-size: 14px;" 
                                                 onAction="#handleRoleSwitch" />
                                    <Label text="Je propose mes services" 
                                           style="-fx-font-size: 12px; -fx-text-fill: #64748B;" />
                                </VBox>
                            </HBox>
                        </HBox>
                    </VBox>
                    
                    <!-- Dynamic Fields Container -->
                    <VBox fx:id="dynamicFieldsBox" spacing="16">
                        <!-- Populated programmatically based on role -->
                    </VBox>
                </VBox>
                
                <!-- Error Label -->
                <Label fx:id="errorLabel" styleClass="error-text" visible="false" managed="false" />
                
                <Region prefHeight="8" />
                
                <!-- Terms -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <CheckBox fx:id="termsCheckbox" />
                    <Label text="J'accepte les " style="-fx-text-fill: #64748B; -fx-font-size: 13px;" />
                    <Hyperlink text="conditions d'utilisation" 
                               style="-fx-text-fill: #4F46E5; -fx-font-size: 13px; -fx-border-color: transparent;" />
                </HBox>
                
                <Region prefHeight="8" />
                
                <!-- Submit Button -->
                <Button fx:id="btnRegister" text="Creer mon compte" styleClass="button, primary" 
                        maxWidth="Infinity" onAction="#handleRegister" prefHeight="48">
                    <graphic>
                        <FontIcon iconLiteral="fth-arrow-right" iconSize="18" style="-fx-icon-color: white;" />
                    </graphic>
                </Button>
                
                <Region prefHeight="12" />
                
                <!-- Login Link -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Deja un compte ?" style="-fx-text-fill: #64748B;" />
                    <Hyperlink text="Se connecter" onAction="#goToLogin" 
                               style="-fx-text-fill: #4F46E5; -fx-font-weight: 600; -fx-border-color: transparent;" />
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
    
    <!-- Right Panel - Branding -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="32" 
          style="-fx-background-color: linear-gradient(to bottom right, #4F46E5, #7C3AED);"
          maxWidth="500">
        <padding>
            <Insets top="60" right="48" bottom="60" left="48" />
        </padding>
        
        <!-- Illustration Area -->
        <VBox alignment="CENTER" spacing="24">
            <StackPane style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 24;"
                       prefWidth="200" prefHeight="200" alignment="CENTER">
                <FontIcon iconLiteral="fth-users" iconSize="80" style="-fx-icon-color: white;" />
            </StackPane>
            
            <VBox alignment="CENTER" spacing="12" maxWidth="350">
                <Label text="Rejoignez notre communaute" 
                       style="-fx-font-size: 26px; -fx-font-weight: 700; -fx-text-fill: white; -fx-text-alignment: center;"
                       wrapText="true" />
                <Label text="Des milliers de professionnels font deja confiance a JobLink pour developper leur activite."
                       style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.85); -fx-text-alignment: center;"
                       wrapText="true" />
            </VBox>
        </VBox>
        
        <Region prefHeight="20" />
        
        <!-- Features -->
        <VBox spacing="16" maxWidth="320">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10;"
                           prefWidth="44" prefHeight="44" alignment="CENTER">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="22" style="-fx-icon-color: white;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Profil verifie" style="-fx-font-size: 15px; -fx-font-weight: 600; -fx-text-fill: white;" />
                    <Label text="Securite et confiance garanties" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7);" />
                </VBox>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="16">
                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10;"
                           prefWidth="44" prefHeight="44" alignment="CENTER">
                    <FontIcon iconLiteral="fth-zap" iconSize="22" style="-fx-icon-color: white;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Mise en relation rapide" style="-fx-font-size: 15px; -fx-font-weight: 600; -fx-text-fill: white;" />
                    <Label text="Trouvez le bon match en minutes" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7);" />
                </VBox>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="16">
                <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 10;"
                           prefWidth="44" prefHeight="44" alignment="CENTER">
                    <FontIcon iconLiteral="fth-shield" iconSize="22" style="-fx-icon-color: white;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Paiements securises" style="-fx-font-size: 15px; -fx-font-weight: 600; -fx-text-fill: white;" />
                    <Label text="Transactions 100% protegees" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7);" />
                </VBox>
            </HBox>
        </VBox>
    </VBox>
</HBox>
