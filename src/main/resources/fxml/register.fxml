<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.joblink.controller.LoginController" prefWidth="1000" prefHeight="700">
    
    <VBox maxWidth="480" maxHeight="650" alignment="CENTER" spacing="15" styleClass="modern-card">
        <padding>
            <Insets top="30" right="40" bottom="30" left="40" />
        </padding>
        
        <FontIcon fx:id="logoIcon" iconLiteral="fth-user-plus" iconSize="42" style="-fx-icon-color: -fx-color-primary;" />
        <Label text="Créer un compte" styleClass="title" />
        
        <VBox spacing="15" VBox.vgrow="ALWAYS" alignment="CENTER_LEFT">
            <padding><Insets top="15" bottom="15" /></padding>
            
            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Nom" styleClass="text-muted" />
                    <TextField fx:id="nomField" promptText="Votre nom" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Prénom" styleClass="text-muted" />
                    <TextField fx:id="prenomField" promptText="Votre prénom" />
                </VBox>
            </HBox>

            <Label text="Adresse Email" styleClass="text-muted" />
            <TextField fx:id="emailField" promptText="exemple@email.com" />
            
            <Label text="Mot de Passe" styleClass="text-muted" />
            <PasswordField fx:id="passwordField" promptText="••••••••" />

            <Label text="Je suis un :" styleClass="text-muted" />
            <HBox spacing="20">
                <RadioButton fx:id="clientRadio" text="Client" styleClass="radio-button" selected="true" onAction="#handleRoleSwitch" />
                <RadioButton fx:id="freelanceRadio" text="Freelance" styleClass="radio-button" onAction="#handleRoleSwitch" />
            </HBox>

            <!-- Dynamic Fields -->
            <VBox fx:id="dynamicFieldsBox" spacing="10">
                <!-- Loaded programmatically -->
            </VBox>
        </VBox>
        
        <Label fx:id="errorLabel" styleClass="error-text" visible="false" managed="false" />
        
        <Button fx:id="btnRegister" text="Créer mon compte" styleClass="button, primary" maxWidth="Infinity" onAction="#handleRegister" />
        
        <HBox alignment="CENTER" spacing="5">
            <Label text="Déjà un compte ?" styleClass="text-muted" />
            <Hyperlink text="Se connecter" onAction="#goToLogin" style="-fx-text-fill: -fx-color-primary; -fx-font-weight: bold; -fx-underline: false; -fx-border-color: transparent;" />
        </HBox>
    </VBox>
</StackPane>
