<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.joblink.controller.ClientHomeController" spacing="25">
    
    <Label text="Tableau de bord" styleClass="title" />
    
    <!-- Stats Row -->
    <HBox spacing="20">
        <VBox styleClass="modern-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="5">
            <Label text="Missions Actives" styleClass="text-muted" />
            <Label fx:id="lblActiveMissions" text="0" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: -fx-color-primary;" />
        </VBox>
        <VBox styleClass="modern-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="5">
            <Label text="Total Dépensé" styleClass="text-muted" />
            <Label fx:id="lblTotalSpent" text="0€" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: -fx-color-success;" />
        </VBox>
        <VBox styleClass="modern-card" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="5">
            <Label text="Propositions en attente" styleClass="text-muted" />
            <Label fx:id="lblPendingProposals" text="0" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: -fx-color-foreground;" />
        </VBox>
    </HBox>

    <Label text="Missions récentes" styleClass="subtitle" style="-fx-font-weight: bold; -fx-text-fill: -fx-color-foreground; -fx-padding: 10 0 0 0;" />
    
    <ScrollPane fitToWidth="true" vbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-padding: 0;">
        <VBox fx:id="recentMissionsBox" spacing="15">
            <!-- Dynamic Mission Cards -->
        </VBox>
    </ScrollPane>
    
</VBox>
