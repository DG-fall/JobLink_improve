<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.joblink.controller.ClientPropositionsController" 
      spacing="20"
      style="-fx-background-color: transparent;">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8" />
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <FontIcon iconLiteral="fth-inbox" iconSize="28" style="-fx-icon-color: -fx-color-primary;" />
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Propositions recues" styleClass="title" />
            <Label text="Consultez et gerez les propositions des freelances" styleClass="subtitle" />
        </VBox>
    </HBox>
    
    <!-- Filters Card -->
    <HBox styleClass="modern-card" spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 16 20;">
        <!-- Mission Filter -->
        <VBox spacing="4">
            <Label text="Filtrer par mission" styleClass="caption" />
            <ComboBox fx:id="missionFilter" promptText="Toutes les missions" prefWidth="280" onAction="#handleMissionFilter"
                      style="-fx-background-color: -fx-color-background-secondary;" />
        </VBox>
        
        <Region HBox.hgrow="ALWAYS" />
        
        <!-- Stats -->
        <HBox spacing="20">
            <VBox alignment="CENTER" spacing="2">
                <Label fx:id="lblTotalPropositions" text="0" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: -fx-color-primary;" />
                <Label text="Total" styleClass="caption" />
            </VBox>
            <Separator orientation="VERTICAL" />
            <VBox alignment="CENTER" spacing="2">
                <Label fx:id="lblPendingPropositions" text="0" style="-fx-font-size: 20px; -fx-font-weight: 700; -fx-text-fill: -fx-color-warning;" />
                <Label text="En attente" styleClass="caption" />
            </VBox>
        </HBox>
    </HBox>

    <!-- Propositions List -->
    <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox fx:id="propositionsBox" spacing="16">
            <padding>
                <Insets top="4" right="4" bottom="20" left="4" />
            </padding>
        </VBox>
    </ScrollPane>
</VBox>
