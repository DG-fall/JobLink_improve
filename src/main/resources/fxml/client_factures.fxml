<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.joblink.controller.ClientFacturesController" 
      spacing="20"
      style="-fx-background-color: transparent;">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8" />
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <FontIcon iconLiteral="fth-credit-card" iconSize="28" style="-fx-icon-color: -fx-color-primary;" />
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Mes Factures" styleClass="title" />
            <Label text="Historique de vos paiements et factures" styleClass="subtitle" />
        </VBox>
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label text="Total Facture" styleClass="caption" />
            <Label fx:id="totalLabel" text="0 EUR" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: -fx-color-primary;" />
        </VBox>
    </HBox>
    
    <!-- Stats Cards -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #DCFCE7; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="18" style="-fx-icon-color: #10B981;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Payees" styleClass="caption" />
                    <Label fx:id="lblPaidCount" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
        
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #FEF3C7; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-clock" iconSize="18" style="-fx-icon-color: #F59E0B;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="En attente" styleClass="caption" />
                    <Label fx:id="lblPendingCount" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
        
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #DBEAFE; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-file-text" iconSize="18" style="-fx-icon-color: #3B82F6;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total Factures" styleClass="caption" />
                    <Label fx:id="lblTotalCount" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
    </HBox>
    
    <!-- Factures Table -->
    <VBox styleClass="modern-card" VBox.vgrow="ALWAYS" spacing="16">
        <HBox alignment="CENTER_LEFT">
            <Label text="Historique des Factures" styleClass="heading" HBox.hgrow="ALWAYS" />
            <Button text="Generer une Facture" styleClass="button, primary" onAction="#generateFacture">
                <graphic>
                    <FontIcon iconLiteral="fth-plus" iconSize="14" style="-fx-icon-color: white;" />
                </graphic>
            </Button>
        </HBox>
        
        <TableView fx:id="facturesTable" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colNumero" text="N Facture" prefWidth="100" />
                <TableColumn fx:id="colMission" text="Mission" prefWidth="280" />
                <TableColumn fx:id="colMontant" text="Montant" prefWidth="120" />
                <TableColumn fx:id="colDate" text="Date emission" prefWidth="140" />
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
                <TableColumn fx:id="colActions" text="Actions" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
