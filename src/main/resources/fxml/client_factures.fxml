<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.joblink.controller.ClientFacturesController" spacing="20">
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Mes Factures" styleClass="title" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="totalLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-color-primary;" />
    </HBox>

    <VBox styleClass="modern-card" VBox.vgrow="ALWAYS" spacing="10">
        <padding><javafx.geometry.Insets top="20" right="20" bottom="20" left="20" /></padding>
        <TableView fx:id="facturesTable" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colNumero" text="N° Facture" prefWidth="100" />
                <TableColumn fx:id="colMission" text="Mission" prefWidth="300" />
                <TableColumn fx:id="colMontant" text="Montant" prefWidth="120" />
                <TableColumn fx:id="colDate" text="Date d'émission" prefWidth="160" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
        <HBox alignment="CENTER_RIGHT">
            <Button text="Générer une Facture" styleClass="button, primary" onAction="#generateFacture" />
        </HBox>
    </VBox>
</VBox>
