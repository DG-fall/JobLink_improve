<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.joblink.controller.LoginController" 
      prefWidth="1200" prefHeight="750" 
      styleClass="auth-container"
      stylesheets="@../css/styles.css">
    
    <!-- Left Panel - Branding -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="24" 
          style="-fx-background-color: linear-gradient(to bottom right, #4F46E5, #7C3AED);">
        <padding>
            <Insets top="60" right="60" bottom="60" left="60" />
        </padding>
        
        <!-- Logo -->
        <HBox alignment="CENTER" spacing="12">
            <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 16;" 
                       prefWidth="56" prefHeight="56" alignment="CENTER">
                <FontIcon iconLiteral="fth-briefcase" iconSize="28" style="-fx-icon-color: white;" />
            </StackPane>
            <Label text="JobLink" style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: white;" />
        </HBox>
        
        <Region prefHeight="20" />
        
        <!-- Tagline -->
        <VBox alignment="CENTER" spacing="12" maxWidth="400">
            <Label text="Connectez talents et opportunites" 
                   style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: white; -fx-text-alignment: center;"
                   wrapText="true" />
            <Label text="La plateforme qui met en relation les meilleurs freelances avec les entreprises qui ont besoin de leurs competences."
                   style="-fx-font-size: 16px; -fx-text-fill: rgba(255,255,255,0.85); -fx-text-alignment: center;"
                   wrapText="true" />
        </VBox>
        
        <Region prefHeight="30" />
        
        <!-- Stats -->
        <HBox alignment="CENTER" spacing="48">
            <VBox alignment="CENTER" spacing="4">
                <Label text="500+" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: white;" />
                <Label text="Freelances" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.7);" />
            </VBox>
            <VBox alignment="CENTER" spacing="4">
                <Label text="1,200+" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: white;" />
                <Label text="Missions" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.7);" />
            </VBox>
            <VBox alignment="CENTER" spacing="4">
                <Label text="98%" style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: white;" />
                <Label text="Satisfaction" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.7);" />
            </VBox>
        </HBox>
    </VBox>
    
    <!-- Right Panel - Login Form -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER" style="-fx-background-color: #F8FAFC;">
        <padding>
            <Insets top="60" right="80" bottom="60" left="80" />
        </padding>
        
        <!-- Login Card -->
        <VBox maxWidth="420" alignment="CENTER_LEFT" spacing="8" styleClass="auth-card">
            
            <!-- Header -->
            <VBox spacing="8" alignment="CENTER">
                <Label text="Bon retour !" styleClass="auth-title" />
                <Label text="Connectez-vous a votre compte pour continuer" styleClass="auth-subtitle" />
            </VBox>
            
            <Region prefHeight="24" />
            
            <!-- Form -->
            <VBox spacing="20">
                <!-- Email -->
                <VBox spacing="8">
                    <Label text="Adresse email" styleClass="form-label" />
                    <HBox styleClass="text-field" style="-fx-padding: 0;">
                        <HBox alignment="CENTER" style="-fx-padding: 0 12 0 16;">
                            <FontIcon iconLiteral="fth-mail" iconSize="18" style="-fx-icon-color: #94A3B8;" />
                        </HBox>
                        <TextField fx:id="emailField" promptText="exemple@email.com" 
                                   style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 12 16 12 8;"
                                   HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                
                <!-- Password -->
                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mot de passe" styleClass="form-label" HBox.hgrow="ALWAYS" />
                        <Hyperlink text="Mot de passe oublie ?" 
                                   style="-fx-text-fill: #4F46E5; -fx-font-size: 13px; -fx-border-color: transparent;" />
                    </HBox>
                    <HBox styleClass="text-field" style="-fx-padding: 0;">
                        <HBox alignment="CENTER" style="-fx-padding: 0 12 0 16;">
                            <FontIcon iconLiteral="fth-lock" iconSize="18" style="-fx-icon-color: #94A3B8;" />
                        </HBox>
                        <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" 
                                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 12 16 12 8;"
                                       HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                
                <!-- Remember me -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <CheckBox text="Se souvenir de moi" style="-fx-text-fill: #64748B;" />
                </HBox>
            </VBox>
            
            <!-- Error Label -->
            <Label fx:id="errorLabel" styleClass="error-text" visible="false" managed="false" />
            
            <Region prefHeight="8" />
            
            <!-- Submit Button -->
            <Button fx:id="btnLogin" text="Se connecter" styleClass="button, primary" 
                    maxWidth="Infinity" onAction="#handleLogin" prefHeight="48">
                <graphic>
                    <FontIcon iconLiteral="fth-log-in" iconSize="18" style="-fx-icon-color: white;" />
                </graphic>
            </Button>
            
            <Region prefHeight="16" />
            
            <!-- Divider -->
            <HBox alignment="CENTER" spacing="16">
                <Separator HBox.hgrow="ALWAYS" />
                <Label text="ou" style="-fx-text-fill: #94A3B8; -fx-font-size: 13px;" />
                <Separator HBox.hgrow="ALWAYS" />
            </HBox>
            
            <Region prefHeight="16" />
            
            <!-- Register Link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Pas encore de compte ?" style="-fx-text-fill: #64748B;" />
                <Hyperlink text="Creer un compte" onAction="#goToRegister" 
                           style="-fx-text-fill: #4F46E5; -fx-font-weight: 600; -fx-border-color: transparent;" />
            </HBox>
        </VBox>
    </VBox>
</HBox>
