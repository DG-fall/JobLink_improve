<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.joblink.controller.FreelanceRevenusController" 
            fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: transparent; -fx-background: transparent;">

    <VBox spacing="24" style="-fx-background-color: transparent;">
        <padding>
            <Insets top="8" right="8" bottom="24" left="8" />
        </padding>
        
        <!-- Welcome Banner -->
        <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="24">
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label fx:id="welcomeLabel" text="Vos Revenus"
                       style="-fx-font-size: 28px; -fx-font-weight: 700; -fx-text-fill: white;" />
                <Label text="Suivez vos gains, missions terminees et performances financieres en temps reel."
                       style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.85); -fx-wrap-text: true;"
                       wrapText="true" maxWidth="450" />
            </VBox>
            <StackPane prefWidth="120" prefHeight="120"
                       style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 20;">
                <FontIcon iconLiteral="fth-dollar-sign" iconSize="50" style="-fx-icon-color: white;" />
            </StackPane>
        </HBox>
        
        <!-- Stats Cards Row -->
        <HBox spacing="20">
            <!-- Total Revenus Card -->
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #D1FAE5; -fx-background-radius: 12;"
                               prefWidth="48" prefHeight="48" alignment="CENTER">
                        <FontIcon iconLiteral="fth-trending-up" iconSize="22" style="-fx-icon-color: #10B981;" />
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Total des Revenus" styleClass="stat-label" />
                        <Label fx:id="lblTotalRevenus" text="0 EUR" styleClass="stat-value"
                               style="-fx-font-size: 32px; -fx-text-fill: #10B981;" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <FontIcon iconLiteral="fth-trending-up" iconSize="14" style="-fx-icon-color: #10B981;" />
                    <Label fx:id="lblRevenusTrend" text="+0% ce mois" styleClass="stat-trend, stat-trend-up" />
                </HBox>
            </VBox>
            
            <!-- Missions Terminees Card -->
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #DBEAFE; -fx-background-radius: 12;"
                               prefWidth="48" prefHeight="48" alignment="CENTER">
                        <FontIcon iconLiteral="fth-check-circle" iconSize="22" style="-fx-icon-color: #3B82F6;" />
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Missions Terminees" styleClass="stat-label" />
                        <Label fx:id="lblMissionsTerminees" text="0" styleClass="stat-value"
                               style="-fx-font-size: 32px;" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="missions reussies" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" />
                </HBox>
            </VBox>
            
            <!-- Note Moyenne Card -->
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #FEF3C7; -fx-background-radius: 12;"
                               prefWidth="48" prefHeight="48" alignment="CENTER">
                        <FontIcon iconLiteral="fth-star" iconSize="22" style="-fx-icon-color: #F59E0B;" />
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Note Moyenne" styleClass="stat-label" />
                        <Label fx:id="lblNoteMoyenne" text="-- / 5" styleClass="stat-value"
                               style="-fx-font-size: 32px;" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <FontIcon iconLiteral="fth-star" iconSize="14" style="-fx-icon-color: #F59E0B;" />
                    <FontIcon iconLiteral="fth-star" iconSize="14" style="-fx-icon-color: #F59E0B;" />
                    <FontIcon iconLiteral="fth-star" iconSize="14" style="-fx-icon-color: #F59E0B;" />
                    <FontIcon iconLiteral="fth-star" iconSize="14" style="-fx-icon-color: #F59E0B;" />
                    <FontIcon iconLiteral="fth-star" iconSize="14" style="-fx-icon-color: #E2E8F0;" />
                </HBox>
            </VBox>
            
            <!-- Missions en Cours Card -->
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="12">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <StackPane style="-fx-background-color: #F3E8FF; -fx-background-radius: 12;"
                               prefWidth="48" prefHeight="48" alignment="CENTER">
                        <FontIcon iconLiteral="fth-clock" iconSize="22" style="-fx-icon-color: #8B5CF6;" />
                    </StackPane>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="En Cours" styleClass="stat-label" />
                        <Label fx:id="lblMissionsEnCours" text="0" styleClass="stat-value"
                               style="-fx-font-size: 32px;" />
                    </VBox>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="missions actives" style="-fx-text-fill: #64748B; -fx-font-size: 13px;" />
                </HBox>
            </VBox>
        </HBox>
        
        <!-- Charts Row -->
        <HBox spacing="20">
            <!-- Revenue Chart -->
            <VBox styleClass="modern-card" HBox.hgrow="ALWAYS" spacing="16" prefHeight="320">
                <HBox alignment="CENTER_LEFT">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Evolution des Revenus" styleClass="heading" />
                        <Label text="Vos revenus mensuels sur les 6 derniers mois" styleClass="caption" />
                    </VBox>
                    <ComboBox fx:id="chartPeriodCombo" promptText="6 mois" prefWidth="100" />
                </HBox>
                <BarChart fx:id="revenusChart" VBox.vgrow="ALWAYS" legendVisible="false"
                          animated="true" barGap="2" categoryGap="20">
                    <xAxis>
                        <CategoryAxis />
                    </xAxis>
                    <yAxis>
                        <NumberAxis />
                    </yAxis>
                </BarChart>
            </VBox>
            
            <!-- Missions by Status Pie Chart -->
            <VBox styleClass="modern-card" prefWidth="340" spacing="16">
                <Label text="Repartition des Missions" styleClass="heading" />
                <PieChart fx:id="missionsChart" prefHeight="200" legendVisible="false" />
                
                <VBox spacing="8">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Region prefWidth="12" prefHeight="12" style="-fx-background-color: #10B981; -fx-background-radius: 3;" />
                        <Label text="Terminees" style="-fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblCompletedCount" text="0" style="-fx-font-weight: 600;" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Region prefWidth="12" prefHeight="12" style="-fx-background-color: #3B82F6; -fx-background-radius: 3;" />
                        <Label text="En cours" style="-fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblInProgressCount" text="0" style="-fx-font-weight: 600;" />
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Region prefWidth="12" prefHeight="12" style="-fx-background-color: #F59E0B; -fx-background-radius: 3;" />
                        <Label text="En attente" style="-fx-font-size: 13px;" HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblPendingCount" text="0" style="-fx-font-weight: 600;" />
                    </HBox>
                </VBox>
            </VBox>
        </HBox>
        
        <!-- Factures Table Section -->
        <VBox styleClass="modern-card" spacing="16" VBox.vgrow="ALWAYS" minHeight="300">
            <HBox alignment="CENTER_LEFT">
                <Label text="Historique des Factures" styleClass="heading" HBox.hgrow="ALWAYS" />
                <Button text="Exporter PDF" styleClass="button, secondary, sm">
                    <graphic>
                        <FontIcon iconLiteral="fth-download" iconSize="14" />
                    </graphic>
                </Button>
            </HBox>
            
            <TableView fx:id="facturesTable" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colMission" text="Mission" prefWidth="300" />
                    <TableColumn fx:id="colClient" text="Client" prefWidth="150" />
                    <TableColumn fx:id="colMontant" text="Montant" prefWidth="120" />
                    <TableColumn fx:id="colDate" text="Date" prefWidth="140" />
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
        
        <Region prefHeight="20" />
        
    </VBox>
</ScrollPane>
