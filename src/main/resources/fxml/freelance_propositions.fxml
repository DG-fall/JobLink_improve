<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.joblink.controller.FreelancePropositionsController" 
      spacing="20"
      style="-fx-background-color: transparent;">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8" />
    </padding>
    
    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <FontIcon iconLiteral="fth-send" iconSize="28" style="-fx-icon-color: -fx-color-primary;" />
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Mes Propositions" styleClass="title" />
            <Label text="Suivez l'etat de vos candidatures aux missions" styleClass="subtitle" />
        </VBox>
    </HBox>
    
    <!-- Stats Cards -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #DBEAFE; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-send" iconSize="18" style="-fx-icon-color: #3B82F6;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Total Envoyees" styleClass="caption" />
                    <Label fx:id="lblTotalSent" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
        
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #FEF3C7; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-clock" iconSize="18" style="-fx-icon-color: #F59E0B;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="En Attente" styleClass="caption" />
                    <Label fx:id="lblPending" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
        
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #DCFCE7; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-check-circle" iconSize="18" style="-fx-icon-color: #10B981;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Acceptees" styleClass="caption" />
                    <Label fx:id="lblAccepted" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
        
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <StackPane style="-fx-background-color: #FEE2E2; -fx-background-radius: 10;"
                           prefWidth="40" prefHeight="40" alignment="CENTER">
                    <FontIcon iconLiteral="fth-x-circle" iconSize="18" style="-fx-icon-color: #EF4444;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Refusees" styleClass="caption" />
                    <Label fx:id="lblRejected" text="0" style="-fx-font-size: 22px; -fx-font-weight: 700;" />
                </VBox>
            </HBox>
        </VBox>
    </HBox>
    
    <!-- Propositions Table -->
    <VBox styleClass="modern-card" VBox.vgrow="ALWAYS" spacing="16">
        <HBox alignment="CENTER_LEFT">
            <Label text="Historique des Propositions" styleClass="heading" HBox.hgrow="ALWAYS" />
            <HBox spacing="8">
                <ComboBox fx:id="statusFilter" promptText="Tous les statuts" prefWidth="150" />
            </HBox>
        </HBox>
        
        <TableView fx:id="propositionsTable" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colMission" text="Mission" prefWidth="300" />
                <TableColumn fx:id="colClient" text="Client" prefWidth="150" />
                <TableColumn fx:id="colMontant" text="Montant Propose" prefWidth="130" />
                <TableColumn fx:id="colDate" text="Date d'envoi" prefWidth="130" />
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="120" />
                <TableColumn fx:id="colActions" text="Actions" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
