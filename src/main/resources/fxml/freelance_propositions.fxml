<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.joblink.controller.FreelancePropositionsController" spacing="20">
    <Label text="Mes Propositions" styleClass="title" />
    
    <VBox styleClass="modern-card" VBox.vgrow="ALWAYS" spacing="10">
        <padding><javafx.geometry.Insets top="20" right="20" bottom="20" left="20" /></padding>
        
        <TableView fx:id="propositionsTable" VBox.vgrow="ALWAYS" style="-fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colMission" text="Mission" prefWidth="350" />
                <TableColumn fx:id="colMontant" text="Montant Proposé" prefWidth="150" />
                <TableColumn fx:id="colDate" text="Date d'envoi" prefWidth="150" />
                <TableColumn fx:id="colStatut" text="Statut" prefWidth="150" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>
</VBox>
